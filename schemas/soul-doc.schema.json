{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/diegoaguirre2828/sidera-protocol/schemas/soul-doc.schema.json",
  "title": "Sidera Soul Document v1",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "updatedAt",
    "owner",
    "voice",
    "vocabulary",
    "projects",
    "commitments",
    "magicMoments",
    "antiPatterns",
    "packPreferences",
    "sources",
    "notes"
  ],
  "properties": {
    "version": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "owner": {
      "type": "object",
      "required": ["handle"],
      "properties": {
        "handle": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string" },
        "locale": { "type": "string" },
        "timezone": { "type": "string" }
      },
      "additionalProperties": false
    },
    "voice": {
      "type": "object",
      "required": ["samples", "registerTags"],
      "properties": {
        "samples": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Verbatim spoken/typed voice samples."
        },
        "registerTags": { "type": "array", "items": { "type": "string" } },
        "cadence": { "type": "string" },
        "modality": {
          "description": "Primary expression modality. Added v1.3.0 — accessibility architecture, not bolt-on.",
          "enum": ["spoken", "signed", "typed", "mixed"]
        },
        "languages": {
          "description": "ISO 639 codes of languages the owner expresses in. Signed languages use ISO 639-3 (e.g. 'ase' = ASL, 'bfi' = BSL, 'bzs' = Libras, 'csl' = CSL, 'jsl' = JSL, 'ksl' = KSL). Multi-language owners list all; first entry is primary. Added v1.3.0.",
          "type": "array",
          "items": { "type": "string" }
        },
        "signedSamples": {
          "description": "Signed-language video samples — first-class peers to text voice.samples, not 'accommodation'. Added v1.3.0.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "recordedAt"],
            "properties": {
              "id": { "type": "string" },
              "language": {
                "description": "ISO 639-3 code of the signed language (e.g. 'ase').",
                "type": "string"
              },
              "caption": {
                "description": "Optional human or AI-generated caption. The owner is the authority — AI captions are hints, not ground truth.",
                "type": "string"
              },
              "captionConfidence": {
                "enum": ["verified", "ai-captioned", "descriptive-only", "unrecognized"]
              },
              "durationMs": { "type": "number" },
              "recordedAt": { "type": "string", "format": "date-time" },
              "storageRef": {
                "description": "Opaque ref to where the clip lives. Local file path, IndexedDB key, or user-controlled object storage. NEVER a Sidera-owned URL. Clip bytes never leave the owner's control.",
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "vocabulary": {
      "type": "object",
      "required": ["phrases", "whistles"],
      "properties": {
        "phrases": { "type": "array", "items": { "type": "string" } },
        "whistles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["phrase", "meaning"],
            "properties": {
              "phrase": { "type": "string" },
              "meaning": { "type": "string" },
              "examples": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "soul": { "type": "string" },
          "status": { "enum": ["active", "paused", "shipped", "archived"] },
          "startedAt": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "commitments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement"],
        "properties": {
          "statement": { "type": "string" },
          "reason": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "magicMoments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "context": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "antiPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "reason": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "packPreferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "preferredModels"],
        "properties": {
          "role": { "enum": ["herder", "guardian", "driver", "other"] },
          "preferredModels": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "ingestedAt", "ref"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "enum": [
              "memory-files",
              "chatgpt-export",
              "claude-export",
              "gemini-export",
              "cursor-export",
              "git-commits",
              "voice-memo",
              "manual-entry",
              "session-capture"
            ]
          },
          "ingestedAt": { "type": "string", "format": "date-time" },
          "ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "body"],
        "properties": {
          "id": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "body": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "aiProfile": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "model", "observations"],
        "properties": {
          "id": { "type": "string" },
          "model": { "type": "string" },
          "surface": { "type": "string" },
          "observations": { "type": "array", "items": { "type": "string" } },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "weaknesses": { "type": "array", "items": { "type": "string" } },
          "lastInteraction": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "graveyard": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "parkedAt"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "context": { "type": "string" },
          "reason": { "type": "string" },
          "parkedAt": { "type": "string", "format": "date-time" },
          "mayRevisit": { "type": "boolean" },
          "revisitTrigger": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "sideraVoice": {
      "type": "object",
      "required": ["samples", "registerTags", "commitments", "pushbackPatterns"],
      "properties": {
        "samples": { "type": "array", "items": { "type": "string" } },
        "registerTags": { "type": "array", "items": { "type": "string" } },
        "commitments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["statement"],
            "properties": {
              "statement": { "type": "string" },
              "reason": { "type": "string" },
              "source": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "pushbackPatterns": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "branches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "createdAt"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "activeContext": { "type": "string" },
          "overrides": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "packScope": {
      "type": "object",
      "required": ["owners"],
      "properties": {
        "owners": { "type": "array", "items": { "type": "string" } },
        "consentPerField": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },
    "manaLedger": {
      "description": "Accumulated weight of work — ships, held commitments, soul-locks, magic moments. Inspired by the Māori concept of mana (dignity + relational authority earned through action). See SPEC.md §Lineage.",
      "type": "object",
      "required": ["cumulative", "events"],
      "properties": {
        "cumulative": { "type": "number" },
        "decayHalfLife": { "type": "string" },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "at", "kind", "weight"],
            "properties": {
              "id": { "type": "string" },
              "at": { "type": "string", "format": "date-time" },
              "kind": {
                "enum": [
                  "ship",
                  "commit-kept",
                  "soul-lock",
                  "magic-moment",
                  "anti-pattern-rejected",
                  "graveyard-decision",
                  "manual"
                ]
              },
              "weight": { "type": "number" },
              "source": { "type": "string" },
              "ref": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "mauriState": {
      "description": "Rolling life-force signal — thriving / steady / depleted. Inferred from humanity-signal density, stop-word frequency, drift patterns. Inspired by the Māori concept of mauri / mauri ora (life-force vitality). See SPEC.md §Lineage.",
      "type": "object",
      "required": ["current", "updatedAt"],
      "properties": {
        "current": { "enum": ["depleted", "steady", "thriving"] },
        "updatedAt": { "type": "string", "format": "date-time" },
        "signals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["at", "indicator", "value"],
            "properties": {
              "at": { "type": "string", "format": "date-time" },
              "indicator": { "type": "string" },
              "value": {}
            },
            "additionalProperties": false
          }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
